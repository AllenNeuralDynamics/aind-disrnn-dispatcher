#!/usr/bin/env bash
set -e

# ------------------------------
# Beaker CLI (AI Hub / Beaker control plane)
# Official installer (docs: AllenOCTO/aihub getting-started/beaker-access.md);
# drops the binary in $HOME/.local/bin (added to PATH here and, for login shells,
# in the Claude Code .bashrc block below).
# Auth is non-interactive via the BEAKER_TOKEN env var (no `beaker account login`).
# ------------------------------
echo "Installing Beaker CLI..."
curl -fsSL https://beaker.org/install | sh || true
export PATH="$HOME/.local/bin:$PATH"
beaker --version || echo "beaker install failed (non-fatal)"


# -------------------------------
# Useful CO extensions
# -------------------------------
# Check if code-server is installed, then install extensions into specified directory
if code-server --disable-telemetry --version; then
    EXT_DIR="/.vscode/extensions"
    if [ ! -d "$EXT_DIR" ]; then
        echo "Directory $EXT_DIR does not exist."
        mkdir -p "$EXT_DIR"
    fi

    # --- For extensions available in the default open-vsx registry ---
    EXTENSIONS=(
        ms-python.python
        ms-toolsai.jupyter
        njpwerner.autodocstring
        KevinRose.vsc-python-indent
        mhutchie.git-graph
        zhuangtongfa.material-theme
        ms-python.black-formatter
        eamodio.gitlens
        ryanluker.vscode-coverage-gutters
        anthropic.claude-code
    )

    for EXT in "${EXTENSIONS[@]}"; do
        code-server --disable-telemetry --extensions-dir="$EXT_DIR" --install-extension "$EXT"
    done

    # --- For extensions not available in the default open-vsx registry ---
    download_and_install_extension() {
        publisher=$1
        name=$2
        version=$3
        file=/tmp/$publisher.$name.$version.vsix
        curl -fL http://${publisher}.gallery.vsassets.io/_apis/public/gallery/publisher/${publisher}/extension/${name}/${version}/assetbyname/Microsoft.VisualStudio.Services.VSIXPackage \
            --output $file
        code-server --extensions-dir=/.vscode/extensions --install-extension $file
    }

    download_and_install_extension github copilot 1.388.0
    download_and_install_extension github copilot-chat 0.32.5

else
    echo "code-server not found"
fi

# ------------------------------
# Claude Code CLI
# ------------------------------
HOME_DIR="${HOME:-/root}"
BASHRC="${HOME_DIR}/.bashrc"

echo "Installing Claude Code..."
curl -fsSL https://claude.ai/install.sh | bash || true
export PATH="$HOME/.local/bin:$PATH"

# Add to bashrc. Single quoted heredoc: nothing here is expanded at write
# time, so $HOME/$SCRATCH/etc. are evaluated at login, when the shell runs.
cat >> "$BASHRC" <<'EOF'

# Claude Code setup
export PATH="$HOME/.local/bin:$PATH"

# ------------------------------
# Persist Claude Code history to /scratch (runs EVERY login, no guard file:
# /root is ephemeral on Code Ocean, /scratch persists, so the symlinks must be
# re-established each session BEFORE claude is launched).
# ------------------------------
# Link durable Claude Code state into persistent /scratch (idempotent)
claude_link_scratch() {
    local SCRATCH=/scratch/.claude
    local LOCAL="$HOME/.claude"
    [ -d /scratch ] || return 0
    mkdir -p "$SCRATCH" "$LOCAL"
    local item src dst
    for item in projects todos plans history.jsonl; do
        src="$LOCAL/$item"
        dst="$SCRATCH/$item"
        # First run on a fresh /scratch: seed the target.
        if [ ! -e "$dst" ]; then
            if [ -e "$src" ] && [ ! -L "$src" ]; then
                cp -a "$src" "$dst"            # migrate pre-existing local data
            elif [ "$item" = "history.jsonl" ]; then
                : > "$dst"                     # empty file
            else
                mkdir -p "$dst"                # empty dir
            fi
        fi
        # Ensure $src is a symlink pointing at $dst (idempotent).
        if [ -L "$src" ]; then
            [ "$(readlink "$src")" = "$dst" ] || { rm -f "$src"; ln -s "$dst" "$src"; }
        else
            [ -e "$src" ] && mv "$src" "$src.pre-link.$(date +%s)"   # stash stray real data
            ln -s "$dst" "$src"
        fi
    done
}
claude_link_scratch
EOF

echo "Claude /scratch persistence added to .bashrc"
