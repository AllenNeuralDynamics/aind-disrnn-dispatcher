# Curated analysis outputs (scaling.json / scaling.csv / fig_scaling.png / reports)
# ARE committed — so the results render directly in the repo tree (Han 2026-07-11:
# "save the latest version of figures/csvs/jsons in the repo so people can see the
# reports in the repo"). Only caches/scratch are ignored.

# W&B download dirs + intermediate per-run pulls (re-derivable from W&B)
analysis/_cache_*.json
analysis/wandb/
analysis/artifacts/

# Python bytecode
__pycache__/
*.pyc

# Legacy names from the pre-normalization layout (now analysis/fig_scaling.png etc.)
ignore_scaling.png
ignore_scaling_3way.csv
